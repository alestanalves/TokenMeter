WIFI_SSID=your-network
WIFI_PASSWORD=your-password

# Personal Codex: run `py -3 server\run_server.py` on your PC and use
# the PC LAN IP address. Do not use localhost in ESP32 firmware.
CODEX_BRIDGE_URL=http://192.168.1.50:8787/api/codex
USE_CODEX=1

# Claude Code also uses the local bridge.
CLAUDE_BRIDGE_URL=http://192.168.1.50:8787/api/claude
USE_CLAUDE=1

# Firmware refresh interval.
USAGE_WINDOW_DAYS=7
REFRESH_INTERVAL_MS=300000

# Optional manual limits for the progress bars. Leave 0 to show local usage only.
CODEX_TOKEN_LIMIT=0
CLAUDE_TOKEN_LIMIT=0

DEVICE_NAME=Token Meter
