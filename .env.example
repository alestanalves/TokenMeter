WIFI_SSID=sua-rede
WIFI_PASSWORD=sua-senha

# Codex pessoal: rode `py -3 server\run_server.py` no PC e use o IP
# da maquina na rede. Nao use localhost na ESP32.
CODEX_BRIDGE_URL=http://192.168.15.12:8787/api/codex
USE_CODEX=1

# Claude Code pessoal tambem usa o bridge local. O limite real precisa ser
# copiado manualmente para server/config.json quando voce quiser ver a barra.
CLAUDE_BRIDGE_URL=http://192.168.15.12:8787/api/claude
USE_CLAUDE=1

# Janela de consulta. A ESP32 consulta um dia por vez para Claude Code.
USAGE_WINDOW_DAYS=7
REFRESH_INTERVAL_MS=300000

# Limites manuais para a barra da tela. Deixe 0 para mostrar so tokens/custo.
CODEX_TOKEN_LIMIT=0
CLAUDE_TOKEN_LIMIT=0

DEVICE_NAME=Token Meter
